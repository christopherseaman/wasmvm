{
  "name": "wasmvm-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-side harness for the wasmvm iPad app: CheerpX (vendored on first run via tools/vendor-cheerpx.sh) + transport shims + xterm.js terminal.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "node scripts/check-vendor.mjs",
    "test:e2e": "playwright test",
    "check:vendor": "node scripts/check-vendor.mjs",
    "vendor:cheerpx": "../tools/vendor-cheerpx.sh"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "idb": "^8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "vitest": "^1.6.0",
    "ws": "^8.17.0"
  }
}
